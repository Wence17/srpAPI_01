# =============================================================================
# Sub2API — unified environment configuration
# =============================================================================
# SECURITY: Copy to repo root `.env` only. Never commit `.env`.
#
#   cp .env.example .env
#
# Used by:
#   - npm run dev / dev:infra (local Next.js + Go API)
#   - docker compose --env-file .env -f deploy/...
#
# Server-side secrets (JWT, DB password, OAuth client secrets) stay here or in
# apps/api/config.yaml — never use NEXT_PUBLIC_* for secrets in apps/web.
# =============================================================================

# --- Local development (npm run dev) ---
BACKEND_URL=http://localhost:8080
WEB_PORT=3000
# Host ports when using deploy/docker-compose.infra.yml (defaults below match compose)
POSTGRES_PORT=5432

# --- Server Configuration ---
# Bind address for host port mapping
BIND_HOST=0.0.0.0

# Server port (exposed on host)
SERVER_PORT=8080

# Server mode: release or debug
SERVER_MODE=release

# -----------------------------------------------------------------------------
# Logging Configuration
# æ—¥å¿—é…ç½®
# -----------------------------------------------------------------------------
# æ—¥å¿—çº§åˆ«ï¼šdebug/info/warn/error
LOG_LEVEL=info
# æ—¥å¿—æ ¼å¼ï¼šjson/console
LOG_FORMAT=json
# æ¯æ¡æ—¥å¿—é™„å¸¦çš„ service å­—æ®µ
LOG_SERVICE_NAME=sub2api
# æ¯æ¡æ—¥å¿—é™„å¸¦çš„ env å­—æ®µ
LOG_ENV=production
# æ˜¯å¦è¾“å‡ºè°ƒç”¨æ–¹ä½ç½®ä¿¡æ¯
LOG_CALLER=true
# å †æ ˆè¾“å‡ºé˜ˆå€¼ï¼šnone/error/fatal
