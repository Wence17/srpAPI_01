# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Set a fixed JWT_SECRET to prevent login sessions from being
# invalidated after container restarts. If left empty, a random secret will
# be generated on each startup, causing all users to be logged out.
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=
# recommended by somtochukwu
# cVL8SBylYxljj61ncBkr6s5H10NOg1AkaxSAg7FsGbI=
JWT_EXPIRE_HOUR=24
# Access Token æœ‰æ•ˆæœŸï¼ˆåˆ†é’Ÿï¼‰
# ä¼˜å…ˆçº§è¯´æ˜Žï¼š
# - >0: æŒ‰åˆ†é’Ÿç”Ÿæ•ˆï¼ˆä¼˜å…ˆäºŽ JWT_EXPIRE_HOURï¼‰
# - =0: å›žé€€ä½¿ç”¨ JWT_EXPIRE_HOUR
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=0

# -----------------------------------------------------------------------------
# TOTP (2FA) Configuration
# TOTPï¼ˆåŒå› ç´ è®¤è¯ï¼‰é…ç½®
# -----------------------------------------------------------------------------
# IMPORTANT: Set a fixed encryption key for TOTP secrets. If left empty, a
# random key will be generated on each startup, causing all existing TOTP
# configurations to become invalid (users won't be able to login with 2FA).
# Generate a secure key: openssl rand -hex 32
# é‡è¦ï¼šè®¾ç½®å›ºå®šçš„ TOTP åŠ å¯†å¯†é’¥ã€‚å¦‚æžœç•™ç©ºï¼Œæ¯æ¬¡å¯åŠ¨å°†ç”Ÿæˆéšæœºå¯†é’¥ï¼Œ
# å¯¼è‡´çŽ°æœ‰çš„ TOTP é…ç½®å¤±æ•ˆï¼ˆç”¨æˆ·æ— æ³•ä½¿ç”¨åŒå› ç´ è®¤è¯ç™»å½•ï¼‰ã€‚
TOTP_ENCRYPTION_KEY=
# recommended by somtochukwu
# aH2UMKz45Wvvi5rN4ae67BwcRratujGyryvz03qa6VY=

