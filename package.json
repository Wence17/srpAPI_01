{
  "name": "sub2api",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev:infra && concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:apps": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "cd apps/api && go run ./cmd/server",
    "dev:infra": "docker compose --env-file .env -f deploy/docker-compose.infra.yml up -d",
    "dev:infra:down": "docker compose --env-file .env -f deploy/docker-compose.infra.yml down",
    "dev:docker": "docker compose --env-file .env -f deploy/docker-compose.dev.yml up --build",
    "build:web": "npm run build -w apps/web",
    "build:api": "make -C apps/api build",
    "css:build": "npm run css:build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
